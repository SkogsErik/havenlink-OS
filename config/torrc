# HavenLink OS - Tor Configuration
# /etc/tor/torrc

# Run as client only (not relay)
SocksPort 127.0.0.1:9050
ControlPort 127.0.0.1:9051

# Disable unused features
DisableDebuggerAttachment 1
DisableNetwork 0

# Logging
Log notice stdout
Log notice syslog

# Data directory
DataDirectory /var/lib/tor
User tor

# Client settings
ClientTransportPlugin obfs4 exec /usr/bin/obfs4proxy
UseBridges 0

# Security settings
# Disable IPv6 for now (reduces attack surface)
IPv6Exit 0

# Don't cache DNS
DNSPort 0

# Performance
CircuitsAvailableTimeout 60
MaxClientCircuitsPending 16

# No exit traffic
ExitPolicy reject *:*

# Cookie authentication for ControlPort
CookieAuthentication 1
